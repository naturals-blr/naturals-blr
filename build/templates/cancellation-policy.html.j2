{% from "macros.j2" import full_footer, footer_css, wa_svg, fb_svg, ig_svg, social_icons, global_mobile_css, social_icons_css, theme_vars, theme_toggle, theme_init_script, button_css, btn_book, btn_wa, btn_call, btn_maps, store_indicator, store_picker_modal, sticky_mobile_bar, store_picker_js, hamburger_nav, tracking_head, tracking_body, stores_json %}
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Cancellation Policy | Naturals Salon &amp; Spa Bangalore</title>
<meta name="description" content="Cancellation policy at Naturals Salon &amp; Spa Bangalore — 24-hour notice required. Learn how to cancel or reschedule your appointment at any of our 5 locations.">
<link rel="canonical" href="https://naturals-blr.github.io/cancellation-policy.html">
<meta property="og:type" content="website">
<meta property="og:title" content="Cancellation Policy | Naturals Salon &amp; Spa Bangalore">
<meta property="og:site_name" content="Naturals Salon &amp; Spa Bangalore">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet">
{{ theme_init_script() }}
{{ tracking_head(gtm_id, pixel_id) }}
<style>
{{ theme_vars() }}
{{ global_mobile_css() }}
*{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{font-family:'Jost',sans-serif;background:var(--cream);color:var(--text);overflow-x:hidden;}
a{text-decoration:none;color:inherit;}
.page-hero{padding-top:70px;background:var(--dark);}
.page-hero-inner{padding:64px 60px 56px;max-width:1380px;margin:0 auto;}
.lbl{font-size:9px;letter-spacing:5px;text-transform:uppercase;color:var(--gold);font-weight:600;margin-bottom:16px;display:flex;align-items:center;gap:12px;}
.lbl::before{content:'';width:18px;height:1px;background:var(--gold);}
.page-hero-inner h1{font-family:'Cormorant Garamond',serif;font-size:clamp(36px,5vw,68px);font-weight:300;color:#fff;line-height:0.95;margin-bottom:14px;}
.page-hero-inner h1 em{font-style:italic;color:var(--gold);}
.page-hero-inner p{font-size:14px;color:rgba(255,255,255,0.45);font-weight:300;line-height:1.8;max-width:600px;}
.policy-wrap{max-width:820px;margin:0 auto;padding:64px 60px;}
.policy-section{margin-bottom:52px;}
.policy-section h2{font-family:'Cormorant Garamond',serif;font-size:28px;font-weight:300;margin-bottom:16px;color:var(--text);}
.policy-section h2 em{font-style:italic;color:var(--green-mid);}
.policy-section p{font-size:14px;color:var(--text-mid);line-height:1.9;font-weight:300;margin-bottom:12px;}
.policy-section ul{padding-left:22px;margin-bottom:14px;}
.policy-section ul li{font-size:14px;color:var(--text-mid);line-height:1.9;font-weight:300;margin-bottom:4px;}
.policy-highlight{background:#fff;border-left:3px solid var(--gold);padding:20px 24px;margin:20px 0;border-radius:0 4px 4px 0;}
.policy-highlight p{margin:0;font-size:14px;color:var(--text);font-weight:400;line-height:1.8;}
.cancel-table{width:100%;border-collapse:collapse;margin:20px 0;font-size:13px;}
.cancel-table th{background:var(--dark);color:#fff;padding:12px 16px;font-size:10px;letter-spacing:2px;text-transform:uppercase;font-weight:600;text-align:left;}
.cancel-table td{padding:13px 16px;color:var(--text-mid);border-bottom:1px solid rgba(0,0,0,0.06);line-height:1.6;}
.cancel-table tr:nth-child(even) td{background:#fff;}
.tier-ok{color:#166534;font-weight:600;}
.tier-warn{color:#92400e;font-weight:600;}
.tier-bad{color:#991b1b;font-weight:600;}
.store-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:20px;}
.store-cancel-card{background:#fff;padding:20px 22px;border-top:2px solid transparent;transition:border-color 0.3s;border-radius:4px;}
.store-cancel-card:hover{border-top-color:var(--gold);}
.scc2-name{font-family:'Cormorant Garamond',serif;font-size:18px;font-weight:400;margin-bottom:3px;}
.scc2-area{font-size:10px;color:var(--gold);letter-spacing:2px;text-transform:uppercase;margin-bottom:8px;}
.scc2-phone{font-size:12px;color:var(--text-mid);margin-top:8px;}
.scc2-phone a{color:var(--green-mid);}
.last-updated{font-size:11px;color:var(--text-light);margin-top:40px;padding-top:20px;border-top:1px solid rgba(0,0,0,0.08);}
{{ button_css() }}
{{ footer_css() }}
{{ social_icons_css() }}
@media(max-width:960px){
  .page-hero-inner{padding:48px 20px 44px;}
  .policy-wrap{padding:40px 20px;}
  .store-grid{grid-template-columns:1fr;}
  .cancel-table{font-size:12px;}
}
@media(max-width:640px){
  img{max-width:100%;height:auto;}
  body{padding-bottom:62px;}
}
</style>
</head>
<body>
{{ tracking_body(gtm_id) }}

{% set base_path = '' %}
{% set active_page = 'home' %}
{% include "header.j2" %}

<div class="page-hero">
  <div class="page-hero-inner">
    <div class="lbl">Our Policies</div>
    <h1>Cancellation <em>Policy</em></h1>
    <p>We understand that plans change. Please review our cancellation guidelines so we can serve all our clients as fairly and smoothly as possible.</p>
  </div>
</div>

<div class="policy-wrap">

  <div class="policy-section">
    <h2>Our <em>Commitment</em> to You</h2>
    <p>At Naturals Salon &amp; Spa, every appointment slot is reserved exclusively for you. Our team prepares in advance — allocating time, products and a stylist specifically for your visit. Last-minute cancellations affect both our team members and other clients who may be waiting for that slot.</p>
    <p>To ensure the highest quality of service for everyone, we kindly ask all clients to observe the following guidelines.</p>
  </div>

  <div class="policy-section">
    <h2>Cancellation <em>Notice Period</em></h2>
    <div class="policy-highlight">
      <p>&#9201;&nbsp; We require a minimum of <strong>24 hours' advance notice</strong> for all appointment cancellations. Cancellations with less than 24 hours' notice may incur a cancellation fee.</p>
    </div>
    <p>This applies to all services — haircuts, colour treatments, facials, spa services, bridal packages and all other appointments at any of our Bangalore stores.</p>
    <table class="cancel-table">
      <tr><th>Notice Given</th><th>Outcome</th></tr>
      <tr><td>48+ hours before appointment</td><td class="tier-ok">&#10003; Free cancellation — full deposit refund</td></tr>
      <tr><td>24–48 hours before appointment</td><td class="tier-ok">&#10003; Free cancellation — rescheduling encouraged</td></tr>
      <tr><td>Less than 24 hours</td><td class="tier-warn">&#9888; Cancellation fee may apply</td></tr>
      <tr><td>No-show (no notice at all)</td><td class="tier-bad">&#10007; Deposit required for future bookings</td></tr>
    </table>
  </div>

  <div class="policy-section">
    <h2>How to <em>Cancel or Reschedule</em></h2>
    <p>You may cancel or reschedule through any of the following channels:</p>
    <ul>
      <li>Via the online booking portal link in your confirmation message</li>
      <li>By calling your store directly during working hours</li>
      <li>Via WhatsApp to your store's number</li>
      <li>By replying to your appointment confirmation SMS</li>
    </ul>
    <p>Store contact details are available on our <a href="contact.html" style="color:var(--green-mid);">Contact Us</a> page.</p>
  </div>

  <div class="policy-section">
    <h2>No-Show <em>Policy</em></h2>
    <p>A no-show is defined as failing to arrive for a scheduled appointment without any prior notice. Clients who no-show may be required to provide a deposit when booking future appointments. This policy helps us treat all our clients fairly and ensures our team's time is respected.</p>
  </div>

  <div class="policy-section">
    <h2>Bridal &amp; <em>Package Bookings</em></h2>
    <p>Bridal packages and pre-paid service bundles are subject to separate cancellation terms agreed at the time of booking. General guidelines:</p>
    <ul>
      <li>Cancelled more than 7 days in advance — full deposit refund</li>
      <li>Cancelled 3–7 days in advance — 50% of deposit retained</li>
      <li>Cancelled less than 3 days in advance — deposit is non-refundable</li>
    </ul>
    <p>Please confirm the specific terms for your package with your store manager at the time of booking.</p>
  </div>

  <div class="policy-section">
    <h2>Exceptions &amp; <em>Special Circumstances</em></h2>
    <p>Genuine emergencies happen. If you cannot provide 24 hours' notice due to a medical emergency or truly unforeseen circumstances, please contact your store as soon as possible. Our team will do their best to accommodate you without a cancellation charge and will happily help you reschedule.</p>
  </div>

  <div class="policy-section">
    <h2>Contact Your <em>Nearest Store</em></h2>
    <p>To cancel or reschedule, reach out to your nearest Naturals Salon directly:</p>
    <div class="store-grid">
    {% for s in stores %}
      <div class="store-cancel-card">
        <div class="scc2-name">{{ s.Store_Name }}</div>
        <div class="scc2-area">{{ s.Area }}</div>
        <div class="scc2-phone">
          <a href="tel:{{ s.Phone_Tel }}">{{ s.Phone_Display }}</a>
        </div>
      </div>
    {% endfor %}
    </div>
  </div>

  <div class="last-updated">Last updated: February 2026 &nbsp;&middot;&nbsp; Questions? <a href="contact.html" style="color:var(--green-mid);">Contact us</a> or see our <a href="booking-policy.html" style="color:var(--green-mid);">Booking Policy</a>.</div>

</div>

{{ full_footer('', stores) }}
{{ stores_json(stores, '') }}
{{ store_picker_modal(stores, '') }}
{{ sticky_mobile_bar('other') }}
{{ store_picker_js() }}
{{ theme_toggle() }}
</body>
</html>

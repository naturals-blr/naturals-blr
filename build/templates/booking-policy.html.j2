{% from "macros.j2" import full_footer, footer_css, wa_svg, fb_svg, ig_svg, social_icons, global_mobile_css, social_icons_css, theme_vars, theme_toggle, theme_init_script, button_css, btn_book, btn_wa, btn_call, btn_maps, store_indicator, store_picker_modal, sticky_mobile_bar, store_picker_js, hamburger_nav, tracking_head, tracking_body, stores_json %}
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Booking Policy | Naturals Salon &amp; Spa Bangalore</title>
<meta name="description" content="Learn how to book, reschedule or cancel an appointment at Naturals Salon &amp; Spa Bangalore. Online, WhatsApp and walk-in options available across 5 locations.">
<link rel="canonical" href="https://naturals-blr.github.io/booking-policy.html">
<meta property="og:type" content="website">
<meta property="og:title" content="Booking Policy | Naturals Salon &amp; Spa Bangalore">
<meta property="og:site_name" content="Naturals Salon &amp; Spa Bangalore">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet">
{{ theme_init_script() }}
{{ tracking_head(gtm_id, pixel_id) }}
<style>
{{ theme_vars() }}
{{ global_mobile_css() }}
*{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{font-family:'Jost',sans-serif;background:var(--cream);color:var(--text);overflow-x:hidden;}
a{text-decoration:none;color:inherit;}
.page-hero{padding-top:70px;background:var(--dark);}
.page-hero-inner{padding:64px 60px 56px;max-width:1380px;margin:0 auto;}
.lbl{font-size:9px;letter-spacing:5px;text-transform:uppercase;color:var(--gold);font-weight:600;margin-bottom:16px;display:flex;align-items:center;gap:12px;}
.lbl::before{content:'';width:18px;height:1px;background:var(--gold);}
.page-hero-inner h1{font-family:'Cormorant Garamond',serif;font-size:clamp(36px,5vw,68px);font-weight:300;color:#fff;line-height:0.95;margin-bottom:14px;}
.page-hero-inner h1 em{font-style:italic;color:var(--gold);}
.page-hero-inner p{font-size:14px;color:rgba(255,255,255,0.45);font-weight:300;line-height:1.8;max-width:600px;}
.policy-wrap{max-width:820px;margin:0 auto;padding:64px 60px;}
.policy-section{margin-bottom:52px;}
.policy-section h2{font-family:'Cormorant Garamond',serif;font-size:28px;font-weight:300;margin-bottom:16px;color:var(--text);}
.policy-section h2 em{font-style:italic;color:var(--green-mid);}
.policy-section p{font-size:14px;color:var(--text-mid);line-height:1.9;font-weight:300;margin-bottom:12px;}
.policy-section ul{padding-left:22px;margin-bottom:14px;}
.policy-section ul li{font-size:14px;color:var(--text-mid);line-height:1.9;font-weight:300;margin-bottom:4px;}
.policy-highlight{background:#fff;border-left:3px solid var(--gold);padding:20px 24px;margin:20px 0;border-radius:0 4px 4px 0;}
.policy-highlight p{margin:0;font-size:14px;color:var(--text);font-weight:400;line-height:1.8;}
.book-methods{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-top:24px;}
.book-method{background:#fff;padding:28px 20px;text-align:center;border-radius:8px;border:1px solid rgba(0,0,0,0.07);}
.book-method-icon{font-size:34px;margin-bottom:12px;}
.book-method-title{font-family:'Cormorant Garamond',serif;font-size:19px;font-weight:400;margin-bottom:8px;}
.book-method-desc{font-size:12px;color:var(--text-light);line-height:1.7;font-weight:300;margin-bottom:16px;}
.steps{display:flex;flex-direction:column;gap:8px;margin-top:20px;}
.step{background:#fff;padding:22px 24px;display:flex;gap:20px;align-items:flex-start;border-radius:6px;border:1px solid rgba(0,0,0,0.07);}
.step-num{font-family:'Cormorant Garamond',serif;font-size:38px;color:var(--gold);font-weight:300;line-height:1;flex-shrink:0;width:38px;}
.step-body h3{font-family:'Cormorant Garamond',serif;font-size:18px;font-weight:400;margin-bottom:5px;}
.step-body p{font-size:13px;color:var(--text-mid);line-height:1.7;font-weight:300;}
.faq-item{border-bottom:1px solid rgba(0,0,0,0.07);padding:18px 0;}
.faq-item:last-child{border-bottom:none;}
.faq-q{font-size:14px;font-weight:600;color:var(--text);margin-bottom:8px;}
.faq-a{font-size:13px;color:var(--text-mid);line-height:1.8;font-weight:300;}
.last-updated{font-size:11px;color:var(--text-light);margin-top:40px;padding-top:20px;border-top:1px solid rgba(0,0,0,0.08);}
{{ button_css() }}
{{ footer_css() }}
{{ social_icons_css() }}
@media(max-width:960px){
  .page-hero-inner{padding:48px 20px 44px;}
  .policy-wrap{padding:40px 20px;}
  .book-methods{grid-template-columns:1fr;}
}
@media(max-width:640px){
  img{max-width:100%;height:auto;}
  body{padding-bottom:62px;}
  .book-method{padding:20px 16px;}
  .step{flex-direction:column;gap:10px;}
  .step-num{width:auto;}
}
</style>
</head>
<body>
{{ tracking_body(gtm_id) }}

{% set base_path = '' %}
{% set active_page = 'home' %}
{% include "header.j2" %}

<div class="page-hero">
  <div class="page-hero-inner">
    <div class="lbl">Our Policies</div>
    <h1>Booking <em>Policy</em></h1>
    <p>Everything you need to know about booking, confirming and rescheduling appointments at Naturals Salon &amp; Spa Bangalore.</p>
  </div>
</div>

<div class="policy-wrap">

  <div class="policy-section">
    <h2>How to <em>Book</em></h2>
    <p>We offer multiple convenient ways to secure your appointment. Choose whichever works best for you:</p>
    <div class="book-methods">
      <div class="book-method">
        <div class="book-method-icon">&#128197;</div>
        <div class="book-method-title">Book Online</div>
        <div class="book-method-desc">Available 24/7 through our booking portal. Select your store, service, stylist and preferred time slot.</div>
        <a href="index.html#our-stores" class="btn-book" style="font-size:10px;padding:10px 16px;">Book Now</a>
      </div>
      <div class="book-method">
        <div class="book-method-icon">&#128172;</div>
        <div class="book-method-title">WhatsApp</div>
        <div class="book-method-desc">Message your preferred store directly. We'll confirm your slot within a few hours during store hours.</div>
        <a href="contact.html" class="btn-wa" style="font-size:10px;padding:10px 16px;">Find Store</a>
      </div>
      <div class="book-method">
        <div class="book-method-icon">&#128222;</div>
        <div class="book-method-title">Call Us</div>
        <div class="book-method-desc">Speak directly with our team, 7 days a week during store hours. We're happy to help you find the right slot.</div>
        <a href="contact.html" class="btn-call" style="font-size:10px;padding:10px 16px;">Find Number</a>
      </div>
    </div>
  </div>

  <div class="policy-section">
    <h2>Booking <em>Steps</em></h2>
    <div class="steps">
      <div class="step">
        <div class="step-num">1</div>
        <div class="step-body">
          <h3>Choose Your Store &amp; Service</h3>
          <p>Browse our <a href="services.html" style="color:var(--green-mid);">services page</a> to explore treatments and pricing. Select the Naturals location nearest to you.</p>
        </div>
      </div>
      <div class="step">
        <div class="step-num">2</div>
        <div class="step-body">
          <h3>Select Date, Time &amp; Stylist</h3>
          <p>Pick an available time slot that suits you. You may request a preferred stylist — subject to their availability on that day.</p>
        </div>
      </div>
      <div class="step">
        <div class="step-num">3</div>
        <div class="step-body">
          <h3>Receive Confirmation</h3>
          <p>You'll receive a confirmation via SMS or WhatsApp with your full appointment details. Please keep this for reference.</p>
        </div>
      </div>
      <div class="step">
        <div class="step-num">4</div>
        <div class="step-body">
          <h3>Arrive &amp; Enjoy</h3>
          <p>Please arrive 5–10 minutes before your scheduled time. Our team will be ready and waiting to take care of you.</p>
        </div>
      </div>
    </div>
  </div>

  <div class="policy-section">
    <h2>Confirmation &amp; <em>Reminders</em></h2>
    <div class="policy-highlight">
      <p>&#9989;&nbsp; All appointments are confirmed at the time of booking. You will receive an automated reminder 24 hours before your scheduled visit.</p>
    </div>
    <p>If you do not receive a confirmation message within 2 hours of booking, please contact your store directly to verify the appointment.</p>
  </div>

  <div class="policy-section">
    <h2>Rescheduling <em>Policy</em></h2>
    <p>We understand that schedules change. You may reschedule at no charge with at least <strong>24 hours' notice</strong>. To reschedule, use the same channel through which you originally booked — online portal, WhatsApp, or phone.</p>
    <p>Rescheduling requests with less than 24 hours' notice are subject to stylist availability and may not always be accommodated on the same day.</p>
  </div>

  <div class="policy-section">
    <h2>Walk-in <em>Appointments</em></h2>
    <p>Walk-ins are always welcome at all our Bangalore locations, subject to stylist availability. During peak hours — weekends and evenings — wait times may be longer. We recommend booking in advance to guarantee your preferred slot and stylist.</p>
    <div class="policy-highlight">
      <p>&#128336;&nbsp; Store hours: Monday–Friday 10:00 AM – 8:00 PM &nbsp;|&nbsp; Saturday–Sunday 9:00 AM – 8:30 PM</p>
    </div>
  </div>

  <div class="policy-section">
    <h2>Group &amp; <em>Bridal Bookings</em></h2>
    <p>For group bookings (3 or more people) or bridal packages, we request at least <strong>48 hours' advance notice</strong> to ensure adequate staffing and preparation. Please contact your preferred store directly to discuss requirements.</p>
    <p>Bridal packages are subject to a separate booking agreement and consultation appointment. We strongly recommend a trial session well ahead of your wedding date.</p>
  </div>

  <div class="policy-section">
    <h2>Frequently Asked <em>Questions</em></h2>
    <div class="faq-item">
      <div class="faq-q">Can I request a specific stylist?</div>
      <div class="faq-a">Yes — request your preferred stylist when booking, subject to their availability on your chosen date. Booking in advance gives the best chance of getting your favourite stylist.</div>
    </div>
    <div class="faq-item">
      <div class="faq-q">What if I arrive late?</div>
      <div class="faq-a">If you arrive more than 15 minutes late, we may need to shorten your service or reschedule to avoid affecting other clients. Please call the store if you're running late.</div>
    </div>
    <div class="faq-item">
      <div class="faq-q">Is there a charge for cancellation?</div>
      <div class="faq-a">Cancellations with at least 24 hours' notice are free. See our <a href="cancellation-policy.html" style="color:var(--green-mid);">Cancellation Policy</a> for full details.</div>
    </div>
    <div class="faq-item">
      <div class="faq-q">Can I book for someone else?</div>
      <div class="faq-a">Yes — please provide the other person's name and contact number when booking so our team can reach them if needed.</div>
    </div>
    <div class="faq-item">
      <div class="faq-q">How do I know my booking is confirmed?</div>
      <div class="faq-a">You'll receive a confirmation SMS or WhatsApp message shortly after booking. If you don't receive one within 2 hours, contact the store directly to verify.</div>
    </div>
  </div>

  <div class="last-updated">Last updated: February 2026 &nbsp;&middot;&nbsp; Questions? <a href="contact.html" style="color:var(--green-mid);">Contact us</a> or see our <a href="cancellation-policy.html" style="color:var(--green-mid);">Cancellation Policy</a>.</div>

</div>

{{ full_footer('', stores) }}
{{ stores_json(stores, '') }}
{{ store_picker_modal(stores, '') }}
{{ sticky_mobile_bar('other') }}
{{ store_picker_js() }}
{{ theme_toggle() }}
</body>
</html>
